# Build artifacts
build/
install/
log/
__pycache__/
.DS_Store

# IDE
.vscode/
.claude/

# Python envs
rl_env/

# Models — store locally in models/, never push
models/
*.pth
*.pkl

# Training live outputs (archived copies go in results/)
logs/
src/my_usv/scripts/curriculum_state.txt
src/my_usv/scripts/test_results.csv
src/my_usv/scripts/test_gui_results.csv
src/my_usv/scripts/training_log.csv
src/my_usv/scripts/phase.txt

# Analysis plots (regenerable from .py scripts)
analisi_maze/plots/
analisi_maze/*.png

# Local-only video demo files (large, never push)
video_maze_*.mp4
*.mp4

# Pacchetti Overleaf zip (rigenerabili) — solo locale
overleaf_*.zip

# Artefatti di training/eval pesanti (checkpoint, CSV per-step). Solo gli
# aggregati in ANALISI_TRAINING/ vanno versionati.
runs/

# ANALISI_TRAINING: versiona SOLO aggregati .csv e note .md.
# Plot .png, summary .txt, backup .pth/.pkl restano locali.
ANALISI_TRAINING/**/*
!ANALISI_TRAINING/**/
!ANALISI_TRAINING/**/*.csv
!ANALISI_TRAINING/**/*.md

# Pacchetto LaTeX/Overleaf (bozza, rigenerabile da report_en.md) — solo locale
DOCUMENTAZIONE/report_5seed_riproducibilita/latex/
DOCUMENTAZIONE/report_feng_vs_ralpha/latex/

# Telegram bot credentials (vedi docs/telegram_bot_setup.md)
.telegram_secrets

# Telegram bridge inter-process files (runtime, mai versionare)
.cascade_status.json
.cascade_control
